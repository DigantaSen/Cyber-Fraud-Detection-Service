# ============================================================
# AI Fraud Detection Platform — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL (Primary) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=platform

# --- PostGIS (Geospatial) ---
POSTGIS_HOST=postgis
# Container-to-container traffic uses the PostGIS container port.
POSTGIS_PORT=5432
# Host access is published separately to avoid colliding with primary Postgres.
POSTGIS_HOST_PORT=5434
POSTGIS_USER=geo_user
POSTGIS_PASSWORD=change_me_postgis
POSTGIS_DB=geospatial


# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j

# --- Redis ---
REDIS_URL=redis://:change_me_redis@redis:6379/0
REDIS_PASSWORD=change_me_redis

# --- OpenSearch ---
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change_me_opensearch

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET_EVIDENCE=evidence
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_EDGE=edge-models

# --- Kong ---
KONG_ADMIN_URL=http://kong:8001

# --- JWT / Auth / Signing ---
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nchange_me\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nchange_me\n-----END PUBLIC KEY-----"
SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nchange_me\n-----END PRIVATE KEY-----"
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Observability ---
OTEL_ENDPOINT=http://tempo:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_VERSION=0.1.0

# --- ML Service URLs (filled when ML services are deployed) ---
ML_SCAM_NLP_URL=http://ml-scam-nlp:8100
ML_COUNTERFEIT_CV_URL=http://ml-counterfeit-cv:8101
ML_GRAPH_ANALYZER_URL=http://ml-graph-analyzer:8102
ML_AUDIO_ANALYZER_URL=http://ml-audio-analyzer:8103

# --- Fusion Config (also set in Redis at startup) ---
FUSION_WEIGHTS_SCAM_NLP=0.40
FUSION_WEIGHTS_CV=0.20
FUSION_WEIGHTS_GRAPH=0.25
FUSION_WEIGHTS_AUDIO=0.15
FUSION_CONFIDENCE_HITL_THRESHOLD=0.60

# --- Groq AI (Scam NLP + Counterfeit CV + Audio Voice Spoof Analyzer) ---
# Shared API key used by ml-scam-nlp, ml-counterfeit-cv, and ml-audio-analyzer.
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ml-scam-nlp text classification model
SCAM_NLP_PROVIDER=groq
GROQ_SCAM_NLP_MODEL=llama-3.3-70b-versatile

# ml-counterfeit-cv vision model
# NOTE: meta-llama/llama-4-scout-17b-16e-instruct was deprecated by Groq and is
# no longer served — qwen/qwen3.6-27b is Groq's current supported vision model
# (see https://console.groq.com/docs/vision). Using the old model ID causes
# an HTTPStatusError and silently falls back to the deterministic stub.
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_TIMEOUT_SECONDS=45

# ml-audio-analyzer: Whisper transcription + LLM spoof classification
AUDIO_ANALYZER_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_AUDIO_LLM_MODEL=qwen/qwen3.6-27b
GROQ_WHISPER_TIMEOUT_SECONDS=60
